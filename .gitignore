# Version Control Ignore Rules for Periyar Entrance Exam Portal

# Sensitive configuration files (Environment variables)
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Python specific files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Node/JavaScript specific files
node_modules/
dist/
dist-ssr/
.vite/
.eslintcache

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Database & Data Exports
*.sql
*.sqlite
*.db
*.xlsx
*.xls
*.csv
/backend/exports/
/backend/uploads/

# IDE and System files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.DS_Store
Thumbs.db

# SSL Certificates
nginx/certs/*.key
nginx/certs/*.crt
nginx/certs/*.pem
!nginx/certs/.gitkeep

# Sensitive Student Data Folder
student-data/

