# ==============================================================================
# Periyar University PG Entrance Examination Management Portal - Backend Configuration
# ==============================================================================
# Copy this file to '.env' and fill in your actual credentials.
# Do NOT commit the '.env' file containing real secrets to version control.

# Application Settings
APP_NAME="Periyar University Entrance Examination Portal API"
ENVIRONMENT="development"  # Options: development, production, staging, prod
SHOW_DOCS=false
API_V1_PREFIX="/api/v1"

# CORS Configuration
# Comma-separated list of allowed origins (no spaces around commas)
BACKEND_CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Database Configuration
# Leave DATABASE_URL empty to dynamically build it from details below.
DATABASE_URL=""
DATABASE_HOST="localhost"
DATABASE_PORT=3306
DATABASE_NAME="periyar_entrance_exam"
DATABASE_USER="root"
DATABASE_PASSWORD="your_database_password_here"

# Security Settings
# IMPORTANT: In production/staging, JWT_SECRET_KEY must be a strong secret of at least 32 characters
JWT_SECRET_KEY="change-this-to-a-long-random-secret"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 1 day in minutes

# Admin Seeding Credentials (Used to auto-populate the administrator table)
# IMPORTANT: In production/staging, change these to strong unique credentials.
ADMIN_USERNAME="change-me-admin"
ADMIN_PASSWORD="change-this-strong-admin-password"
