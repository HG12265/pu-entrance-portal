# ==============================================================================
# Periyar University PG Entrance Examination Management Portal - Docker Compose Configuration
# ==============================================================================
# Copy this file to '.env' in the root directory.
# Update the placeholders with strong, secure credentials before running docker compose.

# MySQL Database Configurations
MYSQL_ROOT_PASSWORD="change-this-root-password"
MYSQL_DATABASE="periyar_entrance_exam"
MYSQL_USER="periyar_user"
MYSQL_PASSWORD="change-this-db-password" 

# Backend Security Configurations
# IMPORTANT: In production, JWT_SECRET_KEY must be a strong secret of at least 32 characters
JWT_SECRET_KEY="change-this-to-a-long-random-secret-minimum-32-chars"

# Admin Seeding Credentials (Used to auto-populate the administrator table)
# IMPORTANT: Change these to strong unique credentials before initial startup.
ADMIN_USERNAME="change-this-admin-username"
ADMIN_PASSWORD="change-this-strong-admin-password"

# API Documentation Settings
SHOW_DOCS=false
